// ===================== SESION ESTUDIANTE =====================

SubProceso SesionEstudiante(nombreE, contraseñaE, NomE, MatE, HorE, ModE, PreE, numE Por Referencia, NomT, MatT, HorT, ModT, CosT, numT, Materias, Horarios, Modalidades)
	
	Definir usuario, clave Como Cadena
	Definir opcion Como Entero
	
	Escribir ""
	Escribir "======== MENU ESTUDIANTE ========="
	Escribir "Ingrese su usuario: "
	Leer usuario
	Escribir "Ingrese su contraseña: "
	Leer clave
	
	Si usuario = nombreE Y clave = contraseñaE Entonces
		
		Escribir "ACCESO PERMITIDO"
		
		Repetir
			
			Escribir ""
			Escribir "===== PANEL ESTUDIANTE ====="
			Escribir "1. Registrarme"
			Escribir "2. Buscar tutor recomendado"
			Escribir "3. Ver todos los tutores"
			Escribir "0. Cerrar sesion"
			
			opcion <- PedirOpcionRango("Elige una opcion: ", 0, 3)
			
			Segun opcion Hacer
				
				1:
					RegistrarEstudiante(NomE, MatE, HorE, ModE, PreE, numE, Materias, Horarios, Modalidades)
					
				2:
					BuscarTutor(NomT, MatT, HorT, ModT, CosT, numT, NomE, MatE, HorE, ModE, PreE, numE, Materias, Horarios, Modalidades)
					
				3:
					VerTutores(NomT, MatT, HorT, ModT, CosT, numT, Materias, Horarios, Modalidades)
					
			FinSegun
			
		Hasta Que opcion = 0
		
		Escribir "Sesion finalizada."
		
	SiNo
		
		Escribir "ACCESO DENEGADO"
		
	FinSi
	
FinSubProceso


