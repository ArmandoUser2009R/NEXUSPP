		FinSegun
		
	Hasta Que decision = 0
	
	Escribir "Fin del programa NEXUSPP."
	
FinAlgoritmo


// ===================== ENTRADA SEGURA (nunca se cae aunque escribas una letra) =====================

Funcion cod <- PedirOpcionRango(mensaje, minOp, maxOp)
	
	Definir entrada Como Cadena
	Definir valido Como Logico
	Definir i Como Entero
	
	Repetir
		
		Escribir mensaje
		Leer entrada
		
		valido <- Falso
		
		Para i <- minOp Hasta maxOp
			Si entrada = ConvertirATexto(i) Entonces
				valido <- Verdadero
			FinSi
		FinPara
		
		Si valido = Falso Entonces
			Escribir "Opcion invalida, ingresa un numero entre ", minOp, " y ", maxOp, "."
		FinSi
		
	Hasta Que valido = Verdadero
	
	cod <- ConvertirANumero(entrada)
	
FinFuncion


