// ===================== REGISTRO DE TUTOR (con menus Segun, sin texto libre) =====================

SubProceso RegistrarTutor(NomT, MatT, HorT, ModT, CosT, numT Por Referencia, Materias, Horarios, Modalidades)
	
	Definir i Como Entero
	
	numT <- numT + 1
	
	Escribir "--- Registro de tutor ---"
	
	Escribir "Nombre del tutor: "
	Leer NomT[numT]
	
	Escribir "Materias disponibles:"
	Para i <- 1 Hasta 5
		Escribir i, ". ", Materias[i]
	FinPara
	MatT[numT] <- PedirOpcionRango("Elige la materia en la que te especializas: ", 1, 5)
	
	Escribir "Horarios disponibles:"
	Para i <- 1 Hasta 10
		Escribir i, ". ", Horarios[i]
	FinPara
	HorT[numT] <- PedirOpcionRango("Elige tu horario disponible: ", 1, 10)
	
	Escribir "Modalidades disponibles:"
	Para i <- 1 Hasta 2
		Escribir i, ". ", Modalidades[i]
	FinPara
	ModT[numT] <- PedirOpcionRango("Elige tu modalidad: ", 1, 2)
	
	Escribir "Costo por hora: "
	Leer CosT[numT]
	
	Escribir "Tutor registrado con exito."
	
FinSubProceso


