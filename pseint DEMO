// ===================== INDICE DE COMPATIBILIDAD (booleanas + porcentaje) =====================

Funcion punt <- CalcularCompatibilidad(matTutor, horTutor, modTutor, costoTutor, matDeseada, horDeseado, modDeseada, presupuesto)
	
	punt <- 0
	
	Si matTutor = matDeseada Entonces
		punt <- punt + 40
	FinSi
	
	Si horTutor = horDeseado Entonces
		punt <- punt + 30
	FinSi
	
	Si costoTutor <= presupuesto Entonces
		punt <- punt + 20
	FinSi
	
	Si modTutor = modDeseada Entonces
		punt <- punt + 10
	FinSi
	
FinFuncion


// ===================== BUSCAR TUTOR RECOMENDADO =====================

SubProceso BuscarTutor(NomT, MatT, HorT, ModT, CosT, numT, NomE, MatE, HorE, ModE, PreE, numE, Materias, Horarios, Modalidades)
	
	Definir idxE, idxT, i, p, horas Como Entero
	Definir costoTotal Como Real
	Definir mejorTutor, mejorPuntaje Como Entero
	
	Si numE = 0 Entonces
		
		Escribir "No hay estudiantes registrados todavia."
		
	SiNo
		
		Si numT = 0 Entonces
			
			Escribir "No hay tutores registrados todavia."
			
		SiNo
			
			Escribir "Estudiantes registrados:"
			Para i <- 1 Hasta numE
				Escribir i, ". ", NomE[i]
			FinPara
			idxE <- PedirOpcionRango("Elige el numero del estudiante: ", 1, numE)
			
			Escribir ""
			Escribir "===== Tutores disponibles para ", NomE[idxE], " ====="
			
			mejorTutor <- 0
			mejorPuntaje <- -1
			
			Para i <- 1 Hasta numT
				
				p <- CalcularCompatibilidad(MatT[i], HorT[i], ModT[i], CosT[i], MatE[idxE], HorE[idxE], ModE[idxE], PreE[idxE])
				
				Escribir i, ". ", NomT[i], " (", Materias[MatT[i]], ", ", Horarios[HorT[i]], ", ", Modalidades[ModT[i]], ") - Compatibilidad: ", p, "%"
				
				Si p > mejorPuntaje Entonces
					mejorPuntaje <- p
					mejorTutor <- i
				FinSi
				
			FinPara
			
			Escribir ""
			Escribir "El tutor mas recomendado es: ", NomT[mejorTutor], " con ", mejorPuntaje, "% de compatibilidad."
			
			Escribir ""
			idxT <- PedirOpcionRango("Con cual tutor quieres calcular el costo (numero): ", 1, numT)
			
			Escribir "Cuantas horas de asesoria deseas? "
			Leer horas
			
			// Operacion algebraica: Costo = Horas x ValorPorHora
			costoTotal <- horas * CosT[idxT]
			
			Escribir ""
			Escribir "===== Detalle del costo ====="
			Escribir "Tutor: ", NomT[idxT]
			Escribir "Horas: ", horas
			Escribir "Costo por hora: $", CosT[idxT]
			Escribir "Costo total: $", costoTotal
			
		FinSi
		
	FinSi
	
FinSubProceso


// ===================== VER TUTORES =====================

SubProceso VerTutores(NomT, MatT, HorT, ModT, CosT, numT, Materias, Horarios, Modalidades)
	
	Definir i Como Entero
	
	Escribir ""
	Escribir "===== LISTA DE TUTORES (", numT, ") ====="
	
	Para i <- 1 Hasta numT
		Escribir i, ". ", NomT[i], " | ", Materias[MatT[i]], " | ", Horarios[HorT[i]], " | ", Modalidades[ModT[i]], " | $", CosT[i], "/hora"
	FinPara
	
FinSubProceso


// ===================== VER ESTUDIANTES =====================

SubProceso VerEstudiantes(NomE, MatE, HorE, ModE, PreE, numE, Materias, Horarios, Modalidades)
	
	Definir i Como Entero
	
	Escribir ""
	Escribir "===== LISTA DE ESTUDIANTES (", numE, ") ====="
	
	Para i <- 1 Hasta numE
		Escribir i, ". ", NomE[i], " | ", Materias[MatE[i]], " | ", Horarios[HorE[i]], " | ", Modalidades[ModE[i]], " | Presupuesto: $", PreE[i]
	FinPara
	
FinSubProceso
